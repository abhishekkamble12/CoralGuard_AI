APP_NAME=CoralGuard AI Backend
ENV=development
DEBUG=true
API_PREFIX=/api/v1
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
DATABASE_URL=postgresql+psycopg2://coralguard:coralguard@postgres:5432/coralguard
REDIS_URL=redis://redis:6379/0
QDRANT_URL=https://your-qdrant-cluster-url.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=reef_knowledge
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o-mini
MODEL_PATH=/app/models/efficientnet_b3_coral_v1.keras
HDBSCAN_MODEL_PATH=/app/models/dbscan_model.pkl
SCALER_PATH=/app/models/scaler.pkl
ALERT_EMAIL_FROM=alerts@coralguard.ai
ALERT_EMAIL_TO=authority@example.gov
ALERT_WEBHOOK_URL=https://example.com/webhook
RATE_LIMIT_PER_MINUTE=60
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
